# ============================================================
# clan-officers-panel — переменные окружения
# Скопируй в .env и заполни. .env не коммитится.
# ============================================================

# --- Сервер ---
HOST=0.0.0.0
PORT=8765
PUBLIC_URL=https://officers-api.trycloudflare.com
FRONTEND_URL=https://buzzword001.github.io/clan-officers-panel
SESSION_SECRET=replace_with_long_random_string

# --- Telegram бот для закрепа ---
# Создать у @BotFather, добавить в офицерский TG-чат с правами админа
TG_BOT_TOKEN=
TG_OFFICER_CHAT_ID=

# --- Telegram Login Widget ---
# Тот же бот что выше. /setdomain у BotFather → buzzword001.github.io
TG_LOGIN_BOT_TOKEN=

# --- VK сообщество для закрепа ---
# Сообщество → Управление → Работа с API → ключ доступа (messages, manage)
VK_GROUP_TOKEN=
VK_OFFICER_PEER_ID=

# --- VK ID OAuth ---
# vk.com/dev → Создать приложение → Standalone
VK_APP_ID=
VK_APP_SECRET=

# --- Whitelist офицеров (путь к JSON-файлам из clan-bridge-admin-bot) ---
WHITELIST_TG_PATH=C:/Users/BuzzWord/clan-bridge-admin-bot/tg_users.json
WHITELIST_VK_PATH=C:/Users/BuzzWord/clan-bridge-admin-bot/vk_users.json

# --- БД и пути ---
DB_PATH=../data/officers.db

# --- Шедулер ---
# Дебаунс перед публикацией обновлённой картинки (минут)
RENDER_DEBOUNCE_MINUTES=5
