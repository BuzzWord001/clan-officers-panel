# ============================================================
# clan-officers-panel — переменные окружения
# Скопируй в .env и заполни. .env не коммитится.
# ============================================================

# --- Сервер ---
HOST=0.0.0.0
PORT=8765
PUBLIC_URL=https://officers-api.trycloudflare.com
FRONTEND_URL=https://buzzword001.github.io/clan-officers-panel
SESSION_SECRET=replace_with_long_random_string

# --- Telegram бот для закрепа в офицерском TG-чате ---
TG_BOT_TOKEN=
TG_OFFICER_CHAT_ID=

# --- VK для закрепа в офицерском VK-чате ---
VK_GROUP_TOKEN=
VK_OFFICER_PEER_ID=

DB_PATH=../data/officers.db
RENDER_DEBOUNCE_MINUTES=5

# --- Дефолтные учётки для первого запуска (потом меняются через /settings.html) ---
DEFAULT_ADMIN_USERNAME=buzzword001
DEFAULT_ADMIN_PASSWORD=change_me_after_first_login
DEFAULT_OFFICER_PASSWORD=change_me_after_first_login
